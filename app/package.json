{
  "name": "resume-assistant",
  "version": "1.0.0",
  "description": "简历助手 - 智能简历匹配与打招呼语生成",
  "main": "www/index.html",
  "scripts": {
    "start": "npx serve www -p 3000",
    "sync": "npx cap sync",
    "android": "npx cap open android",
    "build": "npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "serve": "^14.0.0"
  }
}
